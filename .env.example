# Optional RDKit/FastAPI backend base URL.
# Leave empty to use PubChem fallback for search and 3D SDF generation.
MOLECULE_API_URL=

# Optional public backend URL for hosted Next.js deployments.
# Leave empty so the frontend uses the current site's /api/chem/* routes.
NEXT_PUBLIC_MOLECULE_API_URL=

# Reserved for Vite builds if this app is ever migrated from Next.js.
VITE_MOLECULE_API_URL=

# Optional professional quantum engine base URL.
# The Cloudflare route forwards native app requests to `${QUANTUM_API_URL}/calculate`.
QUANTUM_API_URL=

# Required private bearer token whenever QUANTUM_API_URL is configured.
QUANTUM_API_TOKEN=

# Server-side ChemVault User origin used to authorize cloud quantum requests.
CHEMVAULT_USER_ORIGIN=https://user.chemvault.science

# Comma-separated additional browser origins allowed to call protected quantum routes.
CHEMVAULT_ALLOWED_ORIGINS=

# Private bearer token for the maintainer-only product funnel report.
CHEMVAULT_METRICS_TOKEN=

# Shared secret for the scheduled production dependency monitor.
SYNTHETIC_MONITOR_SECRET=

# Optional desktop API proxy base URL.
# Desktop builds default to https://model.chemvault.science/api/chem.
CHEMVAULT_MODEL_API_URL=https://model.chemvault.science/api/chem

# Optional desktop ChemVault User proxy origin.
CHEMVAULT_USER_ORIGIN=https://user.chemvault.science

# Optional desktop version manifest URL for update enforcement.
CHEMVAULT_APP_VERSION_URL=https://model.chemvault.science/app-version.json

# ChemVault User origin used by the optional sign-in UI.
# Defaults to https://user.chemvault.science when empty.
NEXT_PUBLIC_CHEMVAULT_USER_ORIGIN=https://user.chemvault.science

# Public Molecule Studio origin used as the return target for ChemVault User OAuth/register redirects.
# Defaults to https://model.chemvault.science when empty.
NEXT_PUBLIC_CHEMVAULT_MODEL_ORIGIN=https://model.chemvault.science
