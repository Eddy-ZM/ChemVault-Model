# Optional RDKit/FastAPI backend base URL.
# Leave empty to use PubChem fallback for search and 3D SDF generation.
MOLECULE_API_URL=

# Optional public backend URL for hosted Next.js deployments.
NEXT_PUBLIC_MOLECULE_API_URL=

# Reserved for Vite builds if this app is ever migrated from Next.js.
VITE_MOLECULE_API_URL=
