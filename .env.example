# Optional RDKit/FastAPI backend base URL.
# Leave empty to use PubChem fallback for search and 3D SDF generation.
MOLECULE_API_URL=

# Optional public backend URL for hosted Next.js deployments.
# Leave empty so the frontend uses the current site's /api/chem/* routes.
NEXT_PUBLIC_MOLECULE_API_URL=

# Reserved for Vite builds if this app is ever migrated from Next.js.
VITE_MOLECULE_API_URL=

# Optional future production authentication settings.
# The current Cloudflare static deployment uses a client-side demo auth shell only.
AUTH_SECRET=
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
