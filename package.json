{
  "name": "chemvault-molecule-studio",
  "private": true,
  "description": "ChemVault Model molecular visualization and desktop app package.",
  "author": "ChemVault",
  "license": "UNLICENSED",
  "version": "0.1.0",
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "prepare:assets": "node scripts/copy-vendor-assets.cjs && node scripts/write-version-manifest.cjs",
    "predev": "npm run prepare:assets",
    "dev": "next dev",
    "dev:desktop": "npm run build && node scripts/ensure-electron-binary.cjs && electron .",
    "prebuild": "npm run prepare:assets",
    "build": "next build",
    "build:desktop": "npm run build && node scripts/ensure-electron-binary.cjs && node scripts/patch-nsis-details.cjs && node scripts/build-windows.cjs",
    "dist:win": "npm run build:desktop",
    "release:manifest": "node scripts/write-release-manifest.cjs",
    "metrics:report": "node scripts/fetch-product-report.cjs",
    "notices:generate": "node scripts/generate-third-party-notices.cjs",
    "test": "npm run test:desktop && npm run test:quantum && npm run test:workflow && npm run test:exports",
    "test:desktop": "node scripts/test-versioning.cjs && node scripts/test-run-manifest.cjs && node scripts/test-queue-journal.cjs && node scripts/test-project-store.cjs && node scripts/test-release-record.cjs && node scripts/test-cloud-security.cjs && node scripts/test-product-telemetry.cjs && node scripts/test-desktop-contract.cjs",
    "test:electron-smoke": "node scripts/ensure-electron-binary.cjs && node scripts/test-electron-smoke.cjs",
    "test:electron-workflows": "node scripts/ensure-electron-binary.cjs && node scripts/test-electron-workflows.cjs",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test:exports": "node scripts/smoke-quantum-exports.cjs",
    "test:quantum": "node scripts/test-scientific-benchmarks.cjs && node scripts/test-gaussian-inputs.cjs && node scripts/test-gaussian-parsers.cjs && node scripts/test-engine-parsers.cjs",
    "test:gaussian-live": "node scripts/test-gaussian-live.cjs",
    "test:engines-live": "node scripts/test-engines-live.cjs",
    "test:workflow": "node scripts/test-quantum-workflow.cjs",
    "start": "next start",
    "preview": "npm run build && npx --yes wrangler@4 pages dev out --compatibility-date=2026-06-23 --port 8788",
    "deploy": "npm run build && npx --yes wrangler@4 pages deploy out",
    "lint": "eslint ."
  },
  "dependencies": {
    "3dmol": "^2.5.5",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.20",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "16.2.10"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "build": {
    "appId": "science.chemvault.model",
    "productName": "ChemVault Model",
    "directories": {
      "output": "release/windows"
    },
    "electronVersion": "43.0.0",
    "electronDist": "node_modules/electron/dist",
    "files": [
      "desktop/**/*",
      "out/**/*",
      "public/favicon.ico",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop/quantum",
        "to": "quantum",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh",
      "artifactName": "ChemVault-Model-Setup-${version}-${os}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "language": "1033",
      "installerLanguages": [
        "en_US"
      ],
      "multiLanguageInstaller": false,
      "displayLanguageSelector": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ChemVault Model"
    },
    "portable": {
      "artifactName": "ChemVault-Model-Portable-${version}-${os}-${arch}.${ext}"
    },
    "artifactName": "ChemVault-Model-${version}-${os}-${arch}.${ext}"
  }
}
